rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function groupDoc(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data;
    }

    function isGroupMember(gid) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(gid))
        && request.auth.uid in groupDoc(gid).members;
    }

    // Alinhado com GroupModel.effectiveAdmins: lista vazia ou ausente => só o dono é admin.
    function isGroupAdmin(gid) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(gid))
        && (
          (groupDoc(gid).keys().hasAll(['admins'])
            && groupDoc(gid).admins is list
            && groupDoc(gid).admins.size() > 0
            && request.auth.uid in groupDoc(gid).admins)
          || (groupDoc(gid).keys().hasAll(['admins'])
            && groupDoc(gid).admins is list
            && groupDoc(gid).admins.size() == 0
            && request.auth.uid == groupDoc(gid).ownerId)
          || (!groupDoc(gid).keys().hasAll(['admins'])
            && request.auth.uid == groupDoc(gid).ownerId)
        );
    }

    function isPersonalGroup(gid) {
      return exists(/databases/$(database)/documents/groups/$(gid))
        && groupDoc(gid).get('isPersonal', false) == true;
    }

    function invitePathForSelfUid(gid) {
      return /databases/$(database)/documents/groupInvites/$(gid + '_' + request.auth.uid);
    }

    function invitePathForSelfEmail(gid) {
      return /databases/$(database)/documents/groupInvites/$(gid + '_' + request.auth.token.email);
    }

    function inviteAcceptedForGroupJoin(gid) {
      let okUid = exists(invitePathForSelfUid(gid))
        && get(invitePathForSelfUid(gid)).data.status == 'accepted';
      let okEmail = request.auth != null
        && request.auth.token.email is string
        && exists(invitePathForSelfEmail(gid))
        && get(invitePathForSelfEmail(gid)).data.status == 'accepted';
      return okUid || okEmail;
    }

    function assigneesOkForGroup(gid, task) {
      return !('assigneeIds' in task)
        || task.assigneeIds == null
        || task.assigneeIds.size() == 0
        || assigneesSubsetMembers(gid, task.assigneeIds);
    }

    // Até 10 responsáveis (sem loops nas rules)
    function assigneesSubsetMembers(gid, a) {
      return a is list
        && a.size() <= 10
        && (a.size() < 1 || a[0] in groupDoc(gid).members)
        && (a.size() < 2 || a[1] in groupDoc(gid).members)
        && (a.size() < 3 || a[2] in groupDoc(gid).members)
        && (a.size() < 4 || a[3] in groupDoc(gid).members)
        && (a.size() < 5 || a[4] in groupDoc(gid).members)
        && (a.size() < 6 || a[5] in groupDoc(gid).members)
        && (a.size() < 7 || a[6] in groupDoc(gid).members)
        && (a.size() < 8 || a[7] in groupDoc(gid).members)
        && (a.size() < 9 || a[8] in groupDoc(gid).members)
        && (a.size() < 10 || a[9] in groupDoc(gid).members);
    }

    function emptyAssignees(task) {
      return !('assigneeIds' in task)
        || task.assigneeIds == null
        || task.assigneeIds.size() == 0;
    }

    // Perfil público em users/{uid} — apenas campos não sensíveis (design: firestore-user-profiles).
    function userPublicProfileValid(data) {
      return data is map
        && data.keys().hasOnly(['displayName', 'photoUrl', 'updatedAt'])
        && data.displayName is string
        && data.displayName.size() <= 200
        && data.updatedAt is timestamp
        && (
          !('photoUrl' in data)
          || (data.photoUrl is string && data.photoUrl.size() <= 2000)
        );
    }

    function taskIsPersonal(task) {
      return !('groupId' in task)
        || task.groupId == null;
    }

    function groupTagDocValid(data) {
      return data is map
        && data.keys().hasOnly(['name', 'color'])
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 80
        && data.color is int;
    }

    function taskTagIdsEmpty(task) {
      return !('tagIds' in task)
        || task.tagIds == null
        || task.tagIds.size() == 0;
    }

    function tagIdRefOk(gid, tid) {
      return tid is string
        && tid.size() > 0
        && exists(/databases/$(database)/documents/groups/$(gid)/tags/$(tid));
    }

    // Até 10 tags por tarefa (sem loops dinâmicos nas rules)
    function tagIdsOkForGroupTask(gid, tids) {
      return tids is list
        && tids.size() <= 10
        && (tids.size() < 1 || tagIdRefOk(gid, tids[0]))
        && (tids.size() < 2 || tagIdRefOk(gid, tids[1]))
        && (tids.size() < 3 || tagIdRefOk(gid, tids[2]))
        && (tids.size() < 4 || tagIdRefOk(gid, tids[3]))
        && (tids.size() < 5 || tagIdRefOk(gid, tids[4]))
        && (tids.size() < 6 || tagIdRefOk(gid, tids[5]))
        && (tids.size() < 7 || tagIdRefOk(gid, tids[6]))
        && (tids.size() < 8 || tagIdRefOk(gid, tids[7]))
        && (tids.size() < 9 || tagIdRefOk(gid, tids[8]))
        && (tids.size() < 10 || tagIdRefOk(gid, tids[9]));
    }

    function taskTagIdsValid(task) {
      return taskIsPersonal(task)
        ? taskTagIdsEmpty(task)
        : (
            task.groupId is string
            && task.groupId.size() > 0
            && (
              taskTagIdsEmpty(task)
              || tagIdsOkForGroupTask(task.groupId, task.tagIds)
            )
          );
    }

    function metadataOnlyGroupUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name', 'icon', 'color']);
    }

    function addedOnlySelfToMembers(gid) {
      let before = resource.data.members;
      let after = request.resource.data.members;
      return after is list
        && before is list
        && after.hasAll(before)
        && after.size() == before.size() + 1
        && request.auth.uid in after
        && !(request.auth.uid in before)
        && inviteAcceptedForGroupJoin(gid);
    }

    function adminRemovedMembersOnly(gid) {
      let before = resource.data.members;
      let after = request.resource.data.members;
      let admAfter = request.resource.data.get('admins', []);
      return isGroupAdmin(gid)
        && before is list
        && after is list
        && before.hasAll(after)
        && after.size() < before.size()
        && resource.data.ownerId in after
        && admAfter is list
        && after.hasAll(admAfter);
    }

    match /groups/{groupId} {
      allow read: if signedIn() && request.auth.uid in resource.data.members;

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.members is list
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == request.auth.uid
        && request.resource.data.admins is list
        && request.resource.data.admins.size() == 1
        && request.resource.data.admins[0] == request.auth.uid;

      allow update: if signedIn()
        && resource.data.ownerId == request.resource.data.ownerId
        && (
          (isGroupAdmin(groupId) && metadataOnlyGroupUpdate())
          || addedOnlySelfToMembers(groupId)
          || adminRemovedMembersOnly(groupId)
        );

      allow delete: if signedIn()
        && resource.data.get('isPersonal', false) != true
        && isGroupAdmin(groupId);

      match /tags/{tagId} {
        allow read: if isGroupMember(groupId);

        allow create: if isGroupMember(groupId)
          && groupTagDocValid(request.resource.data);

        allow update: if isGroupMember(groupId)
          && groupTagDocValid(request.resource.data);

        allow delete: if isGroupMember(groupId);
      }
    }

    match /groupInvites/{inviteId} {
      // get() on a missing doc still evaluates read rules; resource is null then, so allow
      // signed-in reads only when absent, otherwise enforce invitee/admin checks on resource.data.
      allow read: if signedIn() && (
        resource == null
        || resource.data.inviteeUid == request.auth.uid
        || (
          resource.data.get('inviteeEmailLower', '') != ''
          && request.auth.token.email == resource.data.inviteeEmailLower
        )
        || isGroupAdmin(resource.data.groupId)
      );

      allow create: if signedIn()
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.groupId is string
        && !isPersonalGroup(request.resource.data.groupId)
        && isGroupAdmin(request.resource.data.groupId)
        && (
          (
            request.resource.data.keys().hasAll([
              'groupId', 'inviteeUid', 'invitedBy', 'status', 'shareToken', 'createdAt'
            ])
            && request.resource.data.inviteeUid is string
            && request.resource.data.inviteeUid.size() > 8
            && inviteId == request.resource.data.groupId + '_' + request.resource.data.inviteeUid
            && request.resource.data.get('inviteeEmailLower', '') == ''
            && request.resource.data.get('shareToken', '') is string
            && request.resource.data.shareToken.size() >= 16
          )
          || (
            request.resource.data.keys().hasAll([
              'groupId', 'inviteeUid', 'inviteeEmailLower', 'invitedBy',
              'status', 'shareToken', 'createdAt'
            ])
            && request.resource.data.inviteeUid == ''
            && request.resource.data.inviteeEmailLower is string
            && request.resource.data.inviteeEmailLower.matches('.*@.*')
            && inviteId == request.resource.data.groupId + '_' + request.resource.data.inviteeEmailLower
            && request.resource.data.shareToken is string
            && request.resource.data.shareToken.size() >= 16
          )
        );

      allow update: if signedIn() && (
        (
          resource.data.inviteeUid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.groupId == resource.data.groupId
          && request.resource.data.inviteeUid == resource.data.inviteeUid
          && request.resource.data.invitedBy == resource.data.invitedBy
          && request.resource.data.get('inviteeEmailLower', '')
            == resource.data.get('inviteeEmailLower', '')
          && request.resource.data.get('shareToken', '')
            == resource.data.get('shareToken', '')
          && request.resource.data.status in ['accepted', 'declined']
        )
        || (
          resource.data.status == 'pending'
          && resource.data.get('inviteeEmailLower', '') != ''
          && request.auth.token.email == resource.data.inviteeEmailLower
          && request.resource.data.groupId == resource.data.groupId
          && request.resource.data.invitedBy == resource.data.invitedBy
          && request.resource.data.inviteeEmailLower == resource.data.inviteeEmailLower
          && request.resource.data.get('shareToken', '')
            == resource.data.get('shareToken', '')
          && request.resource.data.status in ['accepted', 'declined']
          && (
            (
              request.resource.data.status == 'accepted'
              && request.resource.data.inviteeUid == request.auth.uid
            )
            || (
              request.resource.data.status == 'declined'
              && request.resource.data.inviteeUid == resource.data.get('inviteeUid', '')
            )
          )
        )
        || (
          isGroupAdmin(resource.data.groupId)
          && request.resource.data.groupId == resource.data.groupId
          && request.resource.data.inviteeUid == resource.data.inviteeUid
          && request.resource.data.invitedBy == resource.data.invitedBy
          && request.resource.data.get('inviteeEmailLower', '')
            == resource.data.get('inviteeEmailLower', '')
          && request.resource.data.get('shareToken', '')
            == resource.data.get('shareToken', '')
          && request.resource.data.status == 'revoked'
        )
      );

      allow delete: if signedIn() && isGroupAdmin(resource.data.groupId);
    }

    match /tasks/{taskId} {
      allow read: if signedIn() && (
        (taskIsPersonal(resource.data)
          && resource.data.ownerId == request.auth.uid)
        || (resource.data.groupId != null && isGroupMember(resource.data.groupId))
      );

      allow create: if signedIn() && (
        (
          taskIsPersonal(request.resource.data)
          && request.resource.data.ownerId == request.auth.uid
          && emptyAssignees(request.resource.data)
          && taskTagIdsValid(request.resource.data)
        )
        || (
          request.resource.data.groupId != null
          && isGroupMember(request.resource.data.groupId)
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.createdBy == request.auth.uid
          && assigneesOkForGroup(request.resource.data.groupId, request.resource.data)
          && taskTagIdsValid(request.resource.data)
        )
      );

      allow update: if signedIn() && (
        (
          taskIsPersonal(resource.data)
          && resource.data.ownerId == request.auth.uid
          && taskIsPersonal(request.resource.data)
          && request.resource.data.ownerId == request.auth.uid
          && emptyAssignees(request.resource.data)
          && taskTagIdsValid(request.resource.data)
        )
        || (
          request.resource.data.groupId != null
          && resource.data.groupId == request.resource.data.groupId
          && isGroupMember(request.resource.data.groupId)
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.createdBy == resource.data.createdBy
          && assigneesOkForGroup(request.resource.data.groupId, request.resource.data)
          && taskTagIdsValid(request.resource.data)
        )
      );

      allow delete: if signedIn() && (
        (taskIsPersonal(resource.data) && resource.data.ownerId == request.auth.uid)
        || (resource.data.groupId != null && isGroupMember(resource.data.groupId))
      );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && userPublicProfileValid(request.resource.data);
    }

    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
